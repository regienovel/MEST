# MEST AI Studio — Environment Variables
#
# Copy this file to .env.local and fill in your real keys.
# .env.local is gitignored and will never be committed.
#
# DO NOT commit .env.local to git.
# DO NOT paste these keys into chat windows.

# OpenAI API Key (required)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Anthropic API Key (required)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Admin password (required)
# Used to access the /admin panel. Pick something strong.
ADMIN_PASSWORD=change-me-to-something-strong

# Optional: override default settings
# RATE_LIMIT_PER_HOUR=200
